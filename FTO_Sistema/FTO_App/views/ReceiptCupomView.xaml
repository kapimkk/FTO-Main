<UserControl x:Class="FTO_App.Views.ReceiptCupomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="302">

    <UserControl.Resources>
        <Style x:Key="CupomTexto" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="CupomRotulo" TargetType="TextBlock" BasedOn="{StaticResource CupomTexto}">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="CupomValor" TargetType="TextBlock" BasedOn="{StaticResource CupomTexto}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>

        <Style x:Key="CupomLinha" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="CupomEmpresaDetalhe" TargetType="TextBlock" BasedOn="{StaticResource CupomTexto}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Border x:Name="BorderCupom"
            Width="302"
            Background="White"
            Padding="10,18"
            HorizontalAlignment="Left"
            RenderOptions.BitmapScalingMode="HighQuality"
            TextOptions.TextRenderingMode="ClearType"
            TextOptions.TextFormattingMode="Display">
        <StackPanel HorizontalAlignment="Stretch">
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image x:Name="ImgLogo"
                       Grid.Column="0"
                       Width="56"
                       Height="56"
                       VerticalAlignment="Top"
                       Margin="0,0,10,0"
                       Stretch="Uniform"
                       Source="/icons/fto.png"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <TextBlock x:Name="TxtEmpresaNome"
                               Text="FTO Informatica"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="Black"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtEmpresaSubtitulo"
                               Text="Comprovante de servico"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="Black"
                               Margin="0,4,0,0"/>
                    <TextBlock x:Name="TxtEmpresaEndereco"
                               Text="Rua Joao Bettega, 644 - Portao"
                               Style="{StaticResource CupomEmpresaDetalhe}"
                               Margin="0,4,0,0"/>
                    <TextBlock x:Name="TxtEmpresaCidade"
                               Text="Curitiba/PR - CEP 81070-000"
                               Style="{StaticResource CupomEmpresaDetalhe}"
                               Margin="0,3,0,0"/>
                    <TextBlock x:Name="TxtEmpresaTelefone"
                               Text="Tel: (41) 98525-1213"
                               Style="{StaticResource CupomEmpresaDetalhe}"
                               Margin="0,3,0,0"/>
                    <TextBlock x:Name="TxtEmpresaCnpj"
                               Text="CNPJ: 13.416.624/0001-36"
                               Style="{StaticResource CupomEmpresaDetalhe}"
                               Margin="0,3,0,0"/>
                    <TextBlock x:Name="TxtEmpresaIe"
                               Text="IE: 90622917-00"
                               Style="{StaticResource CupomEmpresaDetalhe}"
                               Margin="0,3,0,0"/>
                    <TextBlock Text="CUPOM NAO FISCAL"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="Black"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="Black" Opacity="0.15" Margin="0,0,0,12"/>

            <StackPanel Style="{StaticResource CupomLinha}">
                <TextBlock Text="Venda Nº:" Style="{StaticResource CupomRotulo}"/>
                <TextBlock x:Name="TxtNumeroVenda" Style="{StaticResource CupomValor}"/>
            </StackPanel>
            <StackPanel Style="{StaticResource CupomLinha}">
                <TextBlock Text="Data:" Style="{StaticResource CupomRotulo}"/>
                <TextBlock x:Name="TxtData" Style="{StaticResource CupomValor}"/>
            </StackPanel>
            <StackPanel Style="{StaticResource CupomLinha}" Margin="0,0,0,12">
                <TextBlock Text="Impresso em:" Style="{StaticResource CupomRotulo}"/>
                <TextBlock x:Name="TxtImpressoEm" Style="{StaticResource CupomValor}"/>
            </StackPanel>

            <Border Height="1" Background="Black" Opacity="0.15" Margin="0,0,0,12"/>

            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Servico:" Style="{StaticResource CupomRotulo}" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtServico"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="Black"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Height="1" Background="Black" Opacity="0.15" Margin="0,0,0,8"/>

            <Border Height="2" Background="{DynamicResource PrimaryColor}" Margin="0,4,0,10"/>

            <StackPanel Style="{StaticResource CupomLinha}" Margin="0,0,0,12">
                <TextBlock Text="TOTAL:" FontSize="17" FontWeight="Bold" Foreground="Black"/>
                <TextBlock x:Name="TxtTotal" FontSize="24" FontWeight="Bold" Foreground="Black" Margin="10,0,0,0"/>
            </StackPanel>

            <Border Height="1" Background="Black" Opacity="0.15" Margin="0,0,0,12"/>

            <TextBlock Text="PAGAMENTO" FontSize="13" FontWeight="Bold" Foreground="Black" Margin="0,0,0,8"/>

            <StackPanel Style="{StaticResource CupomLinha}" Margin="0,0,0,12">
                <TextBlock Text="Forma:" Style="{StaticResource CupomRotulo}"/>
                <TextBlock x:Name="TxtFormaPagamento" Style="{StaticResource CupomValor}"/>
            </StackPanel>

            <Border Height="1" Background="Black" Opacity="0.15" Margin="0,0,0,12"/>

            <TextBlock x:Name="TxtRodape"
                       Text="Obrigado pela preferencia!"
                       HorizontalAlignment="Stretch"
                       TextAlignment="Center"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="Black"
                       FontStyle="Italic"/>
        </StackPanel>
    </Border>
</UserControl>
