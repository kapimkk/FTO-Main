<Window x:Class="FTO_App.Views.ConfirmPrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FTO_App.Views"
        Title="Confirmar impressão do cupom"
        Width="440" Height="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Margin="12,12,12,10">
            <local:ReceiptCupomView x:Name="CupomView" HorizontalAlignment="Left"/>
        </ScrollViewer>

        <Border Grid.Row="1" Background="White" Padding="20,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Cancelar" Width="110" Height="36" Margin="0,0,10,0"
                        Background="{DynamicResource CardBackgroundBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Click="BtnCancel_Click"/>
                <Button Content="🖨️ Imprimir" Width="140" Height="36" Margin="0,0,10,0"
                        Style="{StaticResource HoverButtonStyle}"
                        Click="BtnConfirmPrint_Click"/>
                <Button Content="Fechar" Width="100" Height="36"
                        Background="{DynamicResource CardBackgroundBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
